# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aurea_deco
DB_USER=postgres
DB_PASSWORD=your_password_here
# Optional alternative for hosted environments (Render):
# DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Secret (Generate a strong secret key)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_use_64_characters_minimum

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# API Configuration
API_VERSION=v1